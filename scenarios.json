{
  "requests": {
    "health": {
      "headers": {
        "Accept": "application/json"
      },
      "method": "GET",
      "url": "http://localhost:3000/_health"
    },
    "hello": {
      "headers": {
        "Accept": "application/json"
      },
      "method": "GET",
      "url": "http://localhost:3000/hello"
    }
  },
  "run": {
    "concurrency": 10,
    "output": "report.json",
    "output_format": "json",
    "timeout_ms": 5000
  },
  "scenarios": [
    {
      "name": "Warm Up",
      "run": {
        "concurrency": 2,
        "requests": 20000
      },
      "steps": [
        "hello",
        "health"
      ]
    },
    {
      "name": "Steady State",
      "run": {
        "requests": 200000
      },
      "steps": [
        "hello",
        "health"
      ]
    },
    {
      "name": "Over Stress",
      "run": {
        "concurrency": 50,
        "requests": 500000
      },
      "steps": [
        "hello",
        "health"
      ]
    }
  ]
}