{
  "run": {
    "concurrency": 10,
    "timeout_ms": 5000,
    "output_format": "html",
    "output": "report.html"
  },
  "requests": {
    "hello": {
      "url": "http://localhost:3000/hello",
      "method": "GET",
      "headers": { "Accept": "application/json" }
    },
    "health": {
      "url": "http://localhost:3000/_health",
      "method": "GET",
      "headers": { "Accept": "application/json" }
    }
  },
  "scenarios": [
    {
      "name": "Warm Up",
      "run": { "concurrency": 2, "requests": 20 },
      "steps": ["hello", "health"]
    },
    {
      "name": "Steady State",
      "run": { "requests": 200 },
      "steps": ["hello", "health"]
    },
    {
      "name": "Over Stress",
      "run": { "concurrency": 50, "requests": 500 },
      "steps": ["hello", "health"]
    }
  ]
}
